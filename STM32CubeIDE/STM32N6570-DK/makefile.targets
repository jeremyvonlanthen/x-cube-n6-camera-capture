  STM32Cube_FW_N6/Middlewares/Third_Party/VideoEncoder/source/h264/H264Init.o \
  STM32Cube_FW_N6/Middlewares/Third_Party/VideoEncoder/source/h264/H264Mad.o \
  STM32Cube_FW_N6/Middlewares/Third_Party/VideoEncoder/source/h264/H264NalUnit.o \
