  STM32Cube_FW_N6/Middlewares/Third_Party/VideoEncoder/source/h264/H264PutBits.o \
  STM32Cube_FW_N6/Middlewares/Third_Party/VideoEncoder/source/h264/H264RateControl.o \
  STM32Cube_FW_N6/Middlewares/Third_Party/VideoEncoder/source/h264/H264Sei.o \
